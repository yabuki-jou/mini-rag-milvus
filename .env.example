# 应用与本地存储配置。
# 复制本文件为 .env 后再填写实际值，不要把包含密钥的 .env 提交到 Git。
APP_NAME=Mini RAG Milvus
APP_ENV=development
# 相对路径以项目根目录为基准；SQLite 文件的父目录会在启动时创建。
DATABASE_URL=sqlite:///./data/mini_rag.db
# 上传原文件的目录；相对路径以项目根目录为基准。
FILE_STORAGE_DIR=./data/files

# 连接现有的 Milvus，不会自动部署新的 Milvus 实例。
MILVUS_URI=http://localhost:19530
# 本地默认账号仅用于开发环境；生产环境应替换并妥善保管。
MILVUS_TOKEN=root:Milvus
# 所有知识库共用一个 Collection，通过 user_id 和 kb_id 隔离数据。
MILVUS_COLLECTION=mini_rag_handwrite_chunks

# 模型路径可以是绝对路径，也可以是相对于项目根目录的路径。
EMBEDDING_MODEL_PATH=../py-doc-deepseek-server/models/bge-small-zh-v1.5
# 16 GB 内存电脑默认使用 CPU，避免与其他服务争用显存。
EMBEDDING_DEVICE=cpu
# 维度必须与实际 Embedding 模型输出一致，bge-small-zh-v1.5 为 512。
EMBEDDING_DIMENSION=512

# 这里只保留占位符；真实 DeepSeek 密钥应写入本地 .env。
DEEPSEEK_API_KEY=replace-with-your-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
